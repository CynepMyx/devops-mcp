# Docker group GID on your host server
# Run: getent group docker | cut -d: -f3
DOCKER_GID=999

# Comma-separated list of container names that cannot be stopped/restarted
PROTECTED_CONTAINERS=devops-mcp

# Optional: SerpAPI key for search_web tool
SERPAPI_KEY=

# Optional: Exa API key for search_ai tool
EXA_API_KEY=

# Optional: MySQL credentials for db_query tool
ALLOWED_DB_HOST=
ALLOWED_DB_USER=
ALLOWED_DB_PASSWORD=
ALLOWED_DB_NAME=
